#include <iostream>
using namespace std;

bool pairSum(int arr[], int n, int target) {
    int left = 0, right = n - 1;

    while (left < right) {
        int sum = arr[left] + arr[right];

        if (sum == target) return true;
        else if (sum < target) left++;
        else right--;
    }
    return false;
}

int main() {
    int arr[] = {1, 2, 3, 4, 6};
    int n = 5;
    cout << pairSum(arr, n, 6);
}
