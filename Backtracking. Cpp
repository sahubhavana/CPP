#include <iostream>
#include <vector>
using namespace std;

void generateSubsets(vector<int>& nums, vector<int>& curr, int index) {
    if(index == nums.size()) {
        for(int x : curr) cout << x << " ";
        cout << endl;
        return;
    }

    // include
    curr.push_back(nums[index]);
    generateSubsets(nums, curr, index + 1);

    // exclude
    curr.pop_back();
    generateSubsets(nums, curr, index + 1);
}

int main() {
    vector<int> nums = {1, 2, 3};
    vector<int> curr;
    generateSubsets(nums, curr, 0);
}
